# Security
SECRET_KEY=dev-secret-key-change-in-production-123456

# Database
# Use sqlite:///recruitment.db for development, or a full postgresql/mysql URI in production
DATABASE_URL=sqlite:///recruitment.db

# Flask Settings
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

# File Uploads
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=16777216

# Machine Learning
ML_MODEL_PATH=app/ml/models
